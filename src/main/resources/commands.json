{
  "change_app": {
    "description": "Відкриває/закриває програму на комп'ютері",
    "params": {
      "state": {
        "type": "string",
        "enum": ["on", "off"],
        "required": true
      },
      "app_name": {
        "type": "string",
        "enum": ["telegram", "discord", "steam", "firefox", "edge"],
        "required": true
      }
    }
  },
  "change_light": {
    "description": "Керування розумним світлом",
    "params": {
      "state": {
        "type": "string",
        "enum": ["on", "off"],
        "required": false
      },
      "color": {
        "type": "object",
        "properties": {
          "r": {"type": "number", "min": 0, "max": 1},
          "g": {"type": "number", "min": 0, "max": 1},
          "b": {"type": "number", "min": 0, "max": 1}
        },
        "required": false
      }
    }
  }
}